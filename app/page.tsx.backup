            <div className="bg-[#0a1f1a] rounded-2xl p-8 border border-emerald-500/20">
              <div className="space-y-6">
                <div className="flex justify-between items-center pb-4 border-b border-emerald-900/30">
                  <span className="text-gray-400">Энергия</span>
                  <span className="text-white font-bold">45.5 кВт⋅ч</span>
                </div>
                <div className="flex justify-between items-center pb-4 border-b border-emerald-900/30">
                  <span className="text-gray-400">Тариф</span>
                  <span className="text-white font-bold">15.50 сом/кВт⋅ч</span>
                </div>
                <div className="flex justify-between items-center pb-4 border-b border-emerald-900/30">
                  <span className="text-gray-400">Депозит (возврат)</span>
                  <span className="text-emerald-400 font-bold">+100 сом</span>
                </div>
                <div className="flex justify-between items-center text-xl">
